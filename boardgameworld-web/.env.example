# Firebase 웹 앱 설정 JSON (한 줄). .env.production / .env.development 참고.
# VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"...","measurementId":"..."}

# Firestore artifacts/{이 값}/public/... 경로에 사용 (Firebase 콘솔 웹 appId와 다름)
VITE_APP_ID=board-game-app

# Cursor / 호스팅에서 커스텀 토큰이 있을 때만
# VITE_INITIAL_AUTH_TOKEN=
